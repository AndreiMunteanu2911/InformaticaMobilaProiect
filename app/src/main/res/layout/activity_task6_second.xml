<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvTitluFereastraNoua"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fereastra Noua"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1976D2"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date primite de la fereastra anterioara"
            android:textSize="14sp"
            android:textStyle="italic"
            android:textColor="#666666"
            android:layout_marginBottom="32dp"/>

        <!-- Card cu datele primite -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="4dp">

            <!-- Valoarea 1: Nume -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nume primit:"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvNumePrimit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="24dp"/>

            <!-- Valoarea 2: Varsta -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vârstă primită:"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvVarstaPrimita"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="24dp"/>

            <!-- Separator -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="24dp"/>

            <!-- Mesaj confirmare -->
            <TextView
                android:id="@+id/tvMesajConfirmare"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Datele au fost transmise cu succes!"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Buton inapoi -->
        <Button
            android:id="@+id/btnInapoiLaPrima"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inapoi la Prima Fereastră"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"/>

        <!-- Buton inapoi la meniu -->
        <Button
            android:id="@+id/btnInapoiLaMeniu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inapoi la Meniu"
            android:backgroundTint="#757575"/>

    </LinearLayout>
</ScrollView>
