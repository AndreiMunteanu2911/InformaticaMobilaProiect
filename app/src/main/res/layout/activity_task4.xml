<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvTitluTask4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/task4_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/task4_subtitle"
            android:textSize="14sp"
            android:textStyle="italic"
            android:layout_marginBottom="16dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnInapoiTask4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_back"
            android:layout_marginBottom="24dp"/>

        <!-- Element text 1 -->
        <TextView
            android:id="@+id/tvSalut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/salut"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:gravity="center"/>

        <!-- Element text 2 -->
        <TextView
            android:id="@+id/tvMesaj"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mesaj_bun_venit"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"
            android:gravity="center"/>

        <!-- Element imagine -->
        <ImageView
            android:id="@+id/ivSteag"
            android:layout_width="200dp"
            android:layout_height="120dp"
            android:src="@drawable/steag_romania"
            android:contentDescription="@string/steag_descriere"
            android:scaleType="fitCenter"
            android:layout_marginBottom="24dp"/>

        <!-- Selector limba -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/selecteaza_limba"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerLimba"
            android:layout_width="200dp"
            android:layout_height="wrap_content"/>

        <!-- Informatii limba curenta -->
        <TextView
            android:id="@+id/tvLimbaCurenta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            android:textStyle="italic"/>

    </LinearLayout>
</ScrollView>
