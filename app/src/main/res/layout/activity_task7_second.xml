<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTitluTask7Second"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Task 7 - Fragment (Fereastra 2)"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Același fragment ca în Fereastra 1"
        android:textSize="14sp"
        android:textStyle="italic"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnInapoiTask7Second"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inapoi la Fereastra 1"
        android:layout_marginBottom="16dp"/>

    <!-- Informatii despre fragment -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Datele din Fereastra 1 au fost încărcate. Modifică-le și apasă 'Trimite Înapoi' pentru a le trimite la Fereastra 1."
        android:textSize="13sp"
        android:background="#FFF3E0"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <!-- Container pentru Fragment (ACELASI ca in prima fereastra) -->
    <FrameLayout
        android:id="@+id/fragmentContainerSecond"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"/>

    <!-- Afisare confirmare -->
    <TextView
        android:id="@+id/tvConfirmareTrimitere"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#4CAF50"
        android:background="#E8F5E9"
        android:padding="12dp"
        android:gravity="center"/>

</LinearLayout>
