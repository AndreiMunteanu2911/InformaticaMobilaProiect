<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTitluTask2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Task 2 - Filtrare 2 Conditii"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lista cu 6 obiecte + filtrare dupa 2 conditii"
            android:textSize="14sp"
            android:textStyle="italic"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnInapoiTask2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inapoi la Meniu"
            android:layout_marginBottom="16dp"/>

        <!-- Sectiune filtrare -->
        <TextView
            android:id="@+id/tvFiltru"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filtrare după 2 condiții:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- Conditia 1: Stoc maxim -->
        <TextView
            android:id="@+id/tvConditie1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Condiția 1 - Stoc maxim:"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etStocMaxim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="Introduceți stocul maxim (ex: 10)"
            android:layout_marginBottom="12dp"/>

        <!-- Conditia 2: Categorie de exclus -->
        <TextView
            android:id="@+id/tvConditie2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Condiția 2 - Categorie de exclus:"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerCategorieExclusa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <!-- Buton filtrare -->
        <Button
            android:id="@+id/btnFiltreaza"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Filtrează"
            android:layout_marginBottom="16dp"/>

        <!-- Afisare rezultate -->
        <TextView
            android:id="@+id/tvRezultatFiltru"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rezultate filtrare:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvAfisareDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aici vor apărea obiectele filtrate..."
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
